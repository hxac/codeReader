# codeReader 本地 & CI 统一配置（全放这一个文件）
#
# 用法：
#   cp .env.example .env
#   $EDITOR .env          # 填真值
#
# GitHub Actions（Settings → Secrets / Variables）：
#   把下面 ## secrets ## 的值填到仓库 Settings → Secrets；
#   把 ## vars ## 的值填到 Settings → Variables。
#   二者在 workflow tutorial.yml 的 env 块有 || 默认值兜底，不填也可跑。
#
# 🔒 .env 已加入 .gitignore，不会入库。

# ========================================================================== #
#  secrets（密钥 —— 仓库 Settings → Secrets）                               #
# ========================================================================== #
# ① 真 Anthropic 端点（二选一）：
ANTHROPIC_API_KEY=sk-ant-...

# ② 第三方 Anthropic 兼容端点（AUTH_TOKEN 与 BASE_URL 成对使用）：
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://your-endpoint.example.com

# RC_MODEL 可作 secret 或 var（workflow: secrets.RC_MODEL || vars.RC_MODEL || 'claude-sonnet-4-6'）
# 第三方端点常要求特定 model id，放这里当 secret 藏起来：
# RC_MODEL=claude-sonnet-4-6


# ========================================================================== #
#  vars（非密钥调参 —— 仓库 Settings → Variables）                         #
# ========================================================================== #
# Runner 标签（JSON 数组；workflow 的 runs-on 从此读取，未设回退到 ["self-hosted"]）：
# RC_RUNNER_LABELS=["self-hosted"]
RC_CONCURRENCY=3
RC_MAX_TURNS=50
RC_MAX_BUDGET_USD=10.00
RC_TIMEOUT=3600

# Planner 专用上限（只读单次调用，应远小于 worker，避免烧额度）
RC_PLANNER_MAX_TURNS=30
RC_PLANNER_MAX_BUDGET_USD=3.00

# Worker 瞬退避 & 重试
RC_BACKOFF_SEC=0
RC_WORKER_INRUN_RETRIES=1
RC_MAX_RETRIES=5

# 死区（UTC 小时制；默认 6–10 = 北京 14:00–18:00，3× 消耗时段）
RC_DEADZONE_UTC_START=6
RC_DEADZONE_UTC_END=10
RC_DEADZONE_SOFT_MARGIN_MIN=30


# ========================================================================== #
#  workflow_dispatch inputs（act 放 .input 文件；CI 手动触发时填表单）     #
#  放在这里仅作文档参考——这些值由 .input / gh workflow run 表单提供。    #
# ========================================================================== #
# mode=auto                 # full | incremental | auto
# repo_name=                # 只处理某个 owner/repo（留空=repos.yml 全部）
# force_full=false          # 强制全量重建
# ignore_timing=false       # 忽略死区时间守卫（仅调试）
# mock=false                # MOCK 桩（不调 claude、不烧额度）
# debug=false               # 固定单仓库 + 只生成 1 篇 + 忽略死区 + .debug/ 沙箱


# ========================================================================== #
#  直接 env override（Python os.environ 读取；workflow 透传的也都在此）    #
#  一般无需设——workflow 的 env 块已从 inputs/secrets/vars 组装好 RC_*。  #
# ========================================================================== #
# RC_DEBUG=1
# RC_DEBUG_LECTURE_ID=u1-l2
# RC_DEBUG_PERSIST=1
# RC_REPO_NAME=HazyResearch/Megakernels
# RC_MODE=auto
# RC_FORCE_FULL=true
# RC_ALLOW_DEADZONE=1
# RC_MOCK=1
# 路径覆盖（通常不改；selftest 用）
# RC_REPOS_YML=repos.yml
# RC_STATE_FILE=repos_state.json
# RC_WORK_DIR=work
# RC_TUTORIALS_DIR=tutorials
# RC_PROMPTS_DIR=prompts
