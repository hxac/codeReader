# 被分析的仓库工作副本（运行时 clone，不入库）
/work/

# debug 模式沙箱（RC_DEBUG：state/work/tutorials 写这里，不污染正式产物）
/.debug/
.debug/

# act artifact server 本地存储（--artifact-server-path）
/.act-artifacts/
.act-artifacts/

# act 本地调试用的密钥文件
/.secrets
.secrets

# act 本地 var 覆盖（从 .vars.example 复制；非密钥但属本地调参，不入库）
/.vars
.vars

# 个人本地 agent 操作手册（CLAUDE.local.md 约定，不入库）
/CLAUDE.local.md
CLAUDE.local.md

# 日志
*.log

# Python
__pycache__/
*.pyc
.venv/
