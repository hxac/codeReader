# 复制为 .secrets（.gitignore 已忽略 .secrets，不会入库）。
#   cp .secrets.example .secrets
#
# MOCK 模式（act ... --input mock=true）无需任何密钥：走本地桩，不调 claude、不烧额度。
# 只有「有额度真跑」时才需要填下面其一。

# ① 真 Anthropic 端点：
ANTHROPIC_API_KEY=sk-ant-...

# ② 第三方 Anthropic 兼容端点（AUTH_TOKEN 与 BASE_URL 必须成对设置）：
# ANTHROPIC_AUTH_TOKEN=...
# ANTHROPIC_BASE_URL=https://your-endpoint.example.com

# RC_MODEL 可作 secret 或 var（workflow: secrets.RC_MODEL || vars.RC_MODEL || 'claude-sonnet-4-6'）。
# 第三方端点常要求特定 model id，放这里当 secret 藏起来：
# RC_MODEL=claude-sonnet-4-6
